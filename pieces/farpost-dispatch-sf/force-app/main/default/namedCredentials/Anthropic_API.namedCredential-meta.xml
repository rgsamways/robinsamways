<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Anthropic API</label>
    <endpoint>https://api.anthropic.com</endpoint>
    <principalType>NamedUser</principalType>
    <protocol>Password</protocol>
    <username>apikey</username>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <customHeaders>
        <customHeaderName>anthropic-version</customHeaderName>
        <customHeaderValue>2023-06-01</customHeaderValue>
    </customHeaders>
    <customHeaders>
        <customHeaderName>x-api-key</customHeaderName>
        <customHeaderValue>{!$Credential.Password}</customHeaderValue>
    </customHeaders>
</NamedCredential>
